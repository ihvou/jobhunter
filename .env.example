# Copy to .env and fill only the values you approve.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional OpenAI API. If omitted, the bot uses rule-based explanations and draft templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JOBBOT_LOG_LEVEL=INFO

# Local hard budget gate used by the bot before LLM calls.
JOBBOT_DAILY_BUDGET_USD=0.50
JOBBOT_MONTHLY_BUDGET_USD=10.00

# Paths inside Docker. Leave these defaults for docker compose.
JOBBOT_DATA_DIR=/jobbot/data
JOBBOT_INPUT_DIR=/jobbot/input
JOBBOT_CONFIG_DIR=/jobbot/config
JOBBOT_WORKSPACE_DIR=/jobbot/workspace
JOBBOT_DATABASE_PATH=/jobbot/data/jobs.sqlite
JOBBOT_HEARTBEAT_PATH=/jobbot/data/heartbeat
JOBBOT_PROFILE_PATH=/jobbot/input/profile.local.md
JOBBOT_CV_PATH=/jobbot/input/cv.local.md
JOBBOT_PROFILE_SETTINGS_PATH=/jobbot/config/profile.local.json
JOBBOT_SOURCES_PATH=/jobbot/config/sources.json
JOBBOT_SCORING_PATH=/jobbot/config/scoring.json
JOBBOT_SETTINGS_PATH=/jobbot/config/jobbot.json
JOBBOT_CODEX_HANDOFF_MODE=auto

# Optional IMAP read-only alert reader.
# Prefer a dedicated mailbox or folder/label for job alerts.
EMAIL_IMAP_HOST=
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=job-alerts

# Automated Codex worker inside the OpenClaw container.
# Leave model empty to use your Codex CLI default.
OPENCLAW_CODEX_MODEL=
OPENCLAW_POLL_SECONDS=5
OPENCLAW_CODEX_TIMEOUT_SECONDS=900
