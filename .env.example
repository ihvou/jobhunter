# Copy to .env and fill only the values you approve.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional OpenAI API. If omitted, the bot uses rule-based explanations and draft templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JOBHUNTER_LOG_LEVEL=INFO

# Local hard budget gate used by the bot before LLM calls.
JOBHUNTER_DAILY_BUDGET_USD=0.50
JOBHUNTER_MONTHLY_BUDGET_USD=10.00

# Paths inside Docker. Leave these defaults for docker compose.
JOBHUNTER_DATA_DIR=/jobhunter/data
JOBHUNTER_INPUT_DIR=/jobhunter/input
JOBHUNTER_CONFIG_DIR=/jobhunter/config
JOBHUNTER_WORKSPACE_DIR=/jobhunter/workspace
JOBHUNTER_DATABASE_PATH=/jobhunter/data/jobs.sqlite
JOBHUNTER_HEARTBEAT_PATH=/jobhunter/data/heartbeat
JOBHUNTER_PROFILE_PATH=/jobhunter/input/profile.local.md
JOBHUNTER_CV_PATH=/jobhunter/input/cv.local.md
JOBHUNTER_PROFILE_SETTINGS_PATH=/jobhunter/config/profile.local.json
JOBHUNTER_SOURCES_PATH=/jobhunter/config/sources.json
JOBHUNTER_SCORING_PATH=/jobhunter/config/scoring.json
JOBHUNTER_SETTINGS_PATH=/jobhunter/config/jobhunter.json
JOBHUNTER_TASKS_PATH=/jobhunter/repo/tasks.md
JOBHUNTER_CODEX_HANDOFF_MODE=auto
JOBHUNTER_ROBOTS_TXT_RESPECT=ignore

# Optional IMAP read-only alert reader.
# Prefer a dedicated mailbox or folder/label for job alerts.
EMAIL_IMAP_HOST=
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=job-alerts

# Automated Codex worker inside the OpenClaw container.
# Leave model empty to use your Codex CLI default.
OPENCLAW_CODEX_MODEL=
OPENCLAW_POLL_SECONDS=5
OPENCLAW_CODEX_TIMEOUT_SECONDS=900
