# Copy to .env and fill only the values you approve.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional OpenAI API. If omitted, the bot uses rule-based explanations and draft templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Local hard budget gate used by the bot before LLM calls.
JOBBOT_DAILY_BUDGET_USD=0.50
JOBBOT_MONTHLY_BUDGET_USD=10.00

# Paths inside Docker. Leave these defaults for docker compose.
JOBBOT_DATA_DIR=/app/data
JOBBOT_INPUT_DIR=/app/input
JOBBOT_CONFIG_DIR=/app/config
JOBBOT_DATABASE_PATH=/app/data/jobs.sqlite
JOBBOT_PROFILE_PATH=/app/input/profile.md
JOBBOT_SOURCES_PATH=/app/config/sources.json
JOBBOT_SETTINGS_PATH=/app/config/jobbot.json

# Optional IMAP read-only alert reader.
# Prefer a dedicated mailbox or folder/label for job alerts.
EMAIL_IMAP_HOST=
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=job-alerts

# OpenClaw image override for the optional Gateway service.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

