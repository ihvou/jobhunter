#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
COMPOSE=(docker compose --project-directory "$ROOT" --file "$ROOT/docker-compose.yml")
SERVICE_URL="${JOBHUNTER_SERVICE_URL:-http://127.0.0.1:8765}"
GATEWAY_URL="${OPENCLAW_GATEWAY_URL:-http://127.0.0.1:18789}"
DRY_RUN="${OPENCLAW_DRY_RUN:-0}"

usage() {
  cat <<'EOF'
Usage: ./bin/openclaw <command>

Commands:
  start     Build and start jobhunter-service + openclaw-gateway
  stop      Stop jobhunter-service + openclaw-gateway
  restart   Recreate jobhunter-service + openclaw-gateway
  logs      Follow both logs; use "logs gateway" or "logs service"
  status    Show service and gateway status
  shell     Open a shell; use "shell gateway" or "shell service"
  onboard   Run Dockerized OpenClaw onboarding without host daemon install
  set-keyboard  Apply the persistent Telegram 2x2 reply keyboard
  reset-sessions  Clear cached Telegram direct sessions for fresh tool prompts
  cron-install  Register the Phase 4 OpenClaw cron jobs
  cron-list     List OpenClaw cron jobs
  doctor    Run OpenClaw doctor inside the gateway image
  migrate-codex  Run OpenClaw Codex auth migration inside the gateway image
  config    Print suggested OpenClaw config snippet
  help      Show this help
EOF
}

run_cmd() {
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

service_health() {
  local health
  health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' jobhunter-service 2>/dev/null || true)"
  case "$health" in
    healthy|running) printf "ok\n" ;;
    starting) printf "starting\n" ;;
    unhealthy|exited|dead) printf "bad\n" ;;
    *) printf "down\n" ;;
  esac
}

gateway_health() {
  python3 - "$GATEWAY_URL" <<'PY'
import sys
import urllib.request

try:
    with urllib.request.urlopen(sys.argv[1].rstrip("/") + "/health", timeout=2) as response:
        print("ok" if 200 <= response.status < 300 else "bad")
except Exception:
    print("down")
PY
}

wait_gateway_health() {
  local attempt status
  for attempt in $(seq 1 60); do
    status="$(gateway_health)"
    if [ "$status" = "ok" ]; then
      printf "openclaw-gateway health: ok\n"
      return 0
    fi
    sleep 2
  done
  printf "openclaw-gateway health: %s after restart timeout\n" "$status" >&2
  return 1
}

container_state() {
  docker inspect -f '{{.State.Status}}' "$1" 2>/dev/null || printf missing
}

gateway_node() {
  run_cmd "${COMPOSE[@]}" run --rm --no-deps --entrypoint node openclaw-gateway dist/index.js "$@"
}

gateway_node_live() {
  run_cmd "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js "$@"
}

set_keyboard() {
  if [ "$DRY_RUN" = "1" ]; then
    printf '+ docker exec -i openclaw-gateway sh -c %q < set-keyboard-node-script\n' 'node -'
    return 0
  fi
  docker exec -i openclaw-gateway sh -c 'node -' <<'NODE'
const https = require("node:https");

const token = process.env.TELEGRAM_BOT_TOKEN || "";
const chatId = process.env.TELEGRAM_ALLOWED_CHAT_ID || "";
if (!token) {
  console.error("missing TELEGRAM_BOT_TOKEN in openclaw-gateway env");
  process.exit(2);
}
if (!chatId) {
  console.error("missing TELEGRAM_ALLOWED_CHAT_ID in openclaw-gateway env");
  process.exit(2);
}

const payload = JSON.stringify({
  chat_id: chatId,
  text: "Menu updated.",
  reply_markup: {
    keyboard: [
      ["Get more jobs", "My job profile"],
      ["Get more leads", "My ICP profile"],
    ],
    resize_keyboard: true,
    is_persistent: true,
  },
});

const request = https.request(
  {
    hostname: "api.telegram.org",
    path: `/bot${token}/sendMessage`,
    method: "POST",
    headers: {
      "content-type": "application/json",
      "content-length": Buffer.byteLength(payload),
    },
  },
  (response) => {
    let body = "";
    response.setEncoding("utf8");
    response.on("data", (chunk) => {
      body += chunk;
    });
    response.on("end", () => {
      let parsed = {};
      try {
        parsed = JSON.parse(body || "{}");
      } catch {
        console.error(`telegram set-keyboard returned non-JSON HTTP ${response.statusCode}: ${body.slice(0, 300)}`);
        process.exit(1);
      }
      if (!parsed.ok) {
        console.error(`telegram set-keyboard failed: ${parsed.description || body.slice(0, 300)}`);
        process.exit(1);
      }
      console.log(`keyboard set: message_id=${parsed.result && parsed.result.message_id}`);
    });
  },
);

request.on("error", (error) => {
  console.error(`telegram set-keyboard request failed: ${error.message}`);
  process.exit(1);
});
request.end(payload);
NODE
}

reset_sessions() {
  local chat_id=""
  case "${1:-}" in
    "")
      ;;
    --chat)
      if [ -z "${2:-}" ]; then
        printf "reset-sessions: --chat requires a chat id\n" >&2
        return 2
      fi
      chat_id="$2"
      ;;
    *)
      printf "reset-sessions: unknown argument: %s\n" "$1" >&2
      printf "usage: ./bin/openclaw reset-sessions [--chat <chat_id>]\n" >&2
      return 2
      ;;
  esac
  if [ "$DRY_RUN" = "1" ]; then
    printf '+ docker exec -i openclaw-gateway sh -c %q sh %q < reset-sessions-node-script\n' 'node - "$1"' "$chat_id"
    printf '+'
    printf ' %q' "${COMPOSE[@]}" restart openclaw-gateway
    printf '\n'
    return 0
  fi
  docker exec -i openclaw-gateway sh -c 'node - "$1"' sh "$chat_id" <<'NODE'
const fs = require("node:fs");

const chatId = process.argv[2] || "";
const path = "/home/node/.openclaw/agents/jobs/sessions/sessions.json";
const prefix = "agent:jobs:telegram:direct:";
const expected = chatId ? `${prefix}${chatId}` : "";
const data = JSON.parse(fs.readFileSync(path, "utf8"));
const removed = [];

for (const key of Object.keys(data)) {
  if (!key.startsWith(prefix)) continue;
  if (expected && key !== expected) continue;
  removed.push(key);
  delete data[key];
}

if (removed.length) {
  const tmp = `${path}.tmp`;
  fs.writeFileSync(tmp, `${JSON.stringify(data, null, 2)}\n`);
  fs.renameSync(tmp, path);
}

if (removed.length) {
  console.log(`removed session keys: ${removed.join(", ")}`);
} else {
  console.log("removed session keys: none");
}
NODE
  run_cmd "${COMPOSE[@]}" restart openclaw-gateway >/dev/null
  wait_gateway_health
}

config_patch() {
  local payload="$1"
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js config patch --stdin
    printf ' <<< %q\n' "$payload"
  else
    printf '%s\n' "$payload" | "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js config patch --stdin
  fi
}

patch_jobhunter_openclaw_config() {
  local payload
  payload="$(cat <<'JSON'
{
  "channels": {
    "telegram": {
      "capabilities": { "inlineButtons": "dm" },
      "actions": { "sendMessage": true, "editMessage": true, "deleteMessage": true },
      "customCommands": [
        { "command": "jobs",    "description": "Get fresh ranked jobs digest" },
        { "command": "leads",   "description": "Get fresh ranked leads digest" },
        { "command": "sources", "description": "Propose source changes for approval" },
        { "command": "scoring", "description": "Propose scoring rule changes" },
        { "command": "usage",   "description": "Show spend, quota, recent activity" }
      ]
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1
  },
  "mcp": { "servers": { "jobhunter": null } },
  "skills": { "load": { "extraDirs": ["/openclaw/skills"] } },
  "agents": {
    "defaults": {
      "agentRuntime": { "id": "codex" },
      "model": { "primary": "openai-codex/gpt-5.5" },
      "models": { "openai-codex/gpt-5.5": {} },
      "skills": ["jobhunter"],
      "sandbox": { "mode": "off" }
    },
    "list": [
      { "id": "jobs", "name": "Jobhunter", "skills": ["jobhunter"] },
      { "id": "leads", "name": "Leadhunter", "skills": ["leadhunter"] }
    ]
  },
  "plugins": {
    "allow": ["codex", "telegram", "jobhunter-tools", "firecrawl", "exa", "memory-core", "openai"],
    "load": { "paths": ["/opt/jobhunter/plugins/jobhunter-tools"] },
    "entries": {
      "codex": {
        "enabled": true,
        "config": {
          "codexDynamicToolsProfile": "native-first",
          "codexDynamicToolsExclude": [],
          "appServer": {
            "approvalPolicy": "on-request",
            "sandbox": "read-only",
            "serviceTier": "fast"
          }
        }
      },
      "telegram": { "enabled": true },
      "memory-core": { "enabled": true },
      "openai": { "enabled": true },
      "firecrawl": {
        "enabled": true,
        "config": {
          "webFetch": {
            "onlyMainContent": true,
            "maxAgeMs": 86400000,
            "timeoutSeconds": 30
          },
          "webSearch": { "baseUrl": "https://api.firecrawl.dev" }
        }
      },
      "exa": {
        "enabled": true,
        "config": { "webSearch": { "baseUrl": "https://api.exa.ai" } }
      },
      "jobhunter-tools": { "enabled": true },
      "jobhunter-mcp": null
    }
  },
  "tools": {
    "profile": "messaging",
    "alsoAllow": ["web_search", "web_fetch", "jobhunter-tools", "firecrawl", "exa"],
    "deny": ["group:runtime", "group:fs", "group:automation"],
    "web": { "fetch": { "provider": "firecrawl" } },
    "fs": { "workspaceOnly": true },
    "exec": { "security": "deny", "ask": "always" },
    "elevated": { "enabled": false }
  }
}
JSON
)"
  config_patch "$payload"
}

remove_codex_mcp_jobhunter() {
  local cmd=(env HOME=/home/node/.openclaw/agents/main/agent/codex-home /home/node/.openclaw/npm/node_modules/@openai/codex/bin/codex.js mcp remove jobhunter)
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" exec -T openclaw-gateway "${cmd[@]}"
    printf '\n'
  else
    "${COMPOSE[@]}" exec -T openclaw-gateway "${cmd[@]}" || true
  fi
}

cron_exec() {
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js cron "$@"
    printf '\n'
  else
    "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js cron "$@"
  fi
}

cron_upsert_agent_job() {
  local name="$1"
  local schedule="$2"
  local agent="$3"
  local timeout_seconds="$4"
  local deliver="$5"
  local message="$6"
  if [ "$DRY_RUN" = "1" ]; then
    cron_exec rm "$name"
    cron_exec add --name "$name" --cron "$schedule" --agent "$agent" --session isolated --light-context --timeout-seconds "$timeout_seconds" --message "$message" --no-deliver --json
    return
  fi
  "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js cron rm "$name" >/dev/null 2>&1 || true
  if [ "$deliver" = "telegram" ]; then
    "${COMPOSE[@]}" exec -T openclaw-gateway sh -c '
      set -eu
      if [ -n "${TELEGRAM_ALLOWED_CHAT_ID:-}" ]; then
        exec node /app/dist/index.js cron add \
          --name "$1" --cron "$2" --agent "$3" --session isolated --light-context \
          --timeout-seconds "$4" --message "$5" \
          --announce --best-effort-deliver --channel telegram --to "$TELEGRAM_ALLOWED_CHAT_ID" --json
      fi
      exec node /app/dist/index.js cron add \
        --name "$1" --cron "$2" --agent "$3" --session isolated --light-context \
        --timeout-seconds "$4" --message "$5" --no-deliver --json
    ' sh "$name" "$schedule" "$agent" "$timeout_seconds" "$message"
  else
    "${COMPOSE[@]}" exec -T openclaw-gateway node /app/dist/index.js cron add \
      --name "$name" --cron "$schedule" --agent "$agent" --session isolated --light-context \
      --timeout-seconds "$timeout_seconds" --message "$message" --no-deliver --json
  fi
}

install_cron_jobs() {
  cron_upsert_agent_job \
    "jobs-collection" \
    "0 */4 * * *" \
    "jobs" \
    "900" \
    "none" \
    "Scheduled maintenance: call jobhunter_collect_all_sources, then call jobhunter_get_more_jobs with mark_sent=false and summarize only counts. Do not render job cards unless a human asked."
  cron_upsert_agent_job \
    "jobs-rescore-on-feedback-change" \
    "0 6 * * *" \
    "jobs" \
    "900" \
    "none" \
    "Scheduled maintenance: call jobhunter_rescore_recent_jobs with limit=500, then send a concise diagnostic only if the tool reports an error."
  cron_upsert_agent_job \
    "jobs-discovery-monthly" \
    "0 0 1 * *" \
    "jobs" \
    "1800" \
    "telegram" \
    "Scheduled source review: use exa/firecrawl/web tools to look for better job aggregators or public boards for the current profile. If changes are warranted, call jobhunter_propose_actions with sources_proposal. Do not apply changes without user approval."
}

print_config() {
  cat <<EOF
{
  // Dockerized Phase 1.5 config. Gateway runs in container, so paths are
  // container-relative and the Jobhunter service is reached over Compose DNS.
  // Run './bin/openclaw onboard' to apply this config.
  channels: {
    telegram: {
      capabilities: {
        inlineButtons: "dm"
      },
      actions: {
        sendMessage: true
      }
    }
  },
  cron: {
    enabled: true,
    maxConcurrentRuns: 1
  },
  skills: {
    load: {
      extraDirs: ["/openclaw/skills"]
    }
  },
  agents: {
    defaults: {
      agentRuntime: {
        id: "codex"
      },
      model: {
        primary: "openai-codex/gpt-5.5"
      },
      models: {
        "openai-codex/gpt-5.5": {}
      },
      skills: ["jobhunter"],
      sandbox: {
        mode: "off"
      }
    },
    list: [
      {
        id: "jobs",
        name: "Jobhunter",
        skills: ["jobhunter"]
      },
      {
        id: "leads",
        name: "Leadhunter",
        skills: ["leadhunter"]
      }
    ]
  },
  plugins: {
    allow: ["codex", "telegram", "jobhunter-tools", "firecrawl", "exa", "memory-core", "openai"],
    load: {
      paths: ["/opt/jobhunter/plugins/jobhunter-tools"]
    },
    entries: {
      codex: {
        enabled: true,
        config: {
          codexDynamicToolsProfile: "native-first",
          codexDynamicToolsExclude: [],
          appServer: {
            approvalPolicy: "on-request",
            sandbox: "read-only",
            serviceTier: "fast"
          }
        }
      },
      "jobhunter-tools": {
        enabled: true
      },
      telegram: {
        enabled: true
      },
      "memory-core": {
        enabled: true
      },
      openai: {
        enabled: true
      },
      firecrawl: {
        enabled: true,
        config: {
          webFetch: {
            onlyMainContent: true,
            maxAgeMs: 86400000,
            timeoutSeconds: 30
          },
          webSearch: {
            baseUrl: "https://api.firecrawl.dev"
          }
        }
      },
      exa: {
        enabled: true,
        config: {
          webSearch: {
            baseUrl: "https://api.exa.ai"
          }
        }
      }
    }
  },
  tools: {
    profile: "messaging",
    alsoAllow: ["web_search", "web_fetch", "jobhunter-tools", "firecrawl", "exa"],
    deny: ["group:runtime", "group:fs", "group:automation"],
    web: {
      fetch: {
        provider: "firecrawl"
      }
    },
    fs: { workspaceOnly: true },
    exec: { security: "deny", ask: "always" },
    elevated: { enabled: false }
  }
}
EOF
}

case "${1:-help}" in
  help|-h|--help)
    usage
    ;;
  start)
    run_cmd "${COMPOSE[@]}" build jobhunter-service openclaw-gateway
    run_cmd "${COMPOSE[@]}" up -d jobhunter-service openclaw-gateway
    printf "jobhunter-service: %s\n" "$(service_health)"
    printf "openclaw-gateway: %s\n" "$(gateway_health)"
    printf "\nRun './bin/openclaw onboard' once before first Telegram pairing.\n"
    ;;
  stop)
    run_cmd "${COMPOSE[@]}" stop openclaw-gateway jobhunter-service
    ;;
  restart)
    run_cmd "${COMPOSE[@]}" up -d --force-recreate --build jobhunter-service openclaw-gateway
    printf "jobhunter-service: %s\n" "$(service_health)"
    printf "openclaw-gateway: %s\n" "$(gateway_health)"
    ;;
  logs)
    case "${2:-all}" in
      gateway)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" openclaw-gateway
        ;;
      service)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" jobhunter-service
        ;;
      all)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" jobhunter-service openclaw-gateway
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    ;;
  status)
    printf "jobhunter-service:%s health:%s\n" "$(container_state jobhunter-service)" "$(service_health)"
    printf "openclaw-gateway:%s health:%s\n" "$(container_state openclaw-gateway)" "$(gateway_health)"
    ;;
  shell)
    case "${2:-service}" in
      gateway)
        run_cmd "${COMPOSE[@]}" exec openclaw-gateway sh
        ;;
      service)
        run_cmd "${COMPOSE[@]}" exec jobhunter-service sh
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    ;;
  onboard)
    gateway_node onboard --mode local --no-install-daemon
    gateway_node_live config set --batch-json '[{"path":"gateway.mode","value":"local"},{"path":"gateway.bind","value":"lan"},{"path":"gateway.controlUi.allowedOrigins","value":["http://localhost:18789","http://127.0.0.1:18789"]}]'
    patch_jobhunter_openclaw_config
    remove_codex_mcp_jobhunter
    set_keyboard
    if install_cron_jobs; then
      printf "\nOnboarding finished. Jobhunter OpenClaw plugin, skills, Telegram, Codex runtime, and cron jobs are configured.\n"
    else
      printf "\nOnboarding finished, but cron registration needs one more step.\n"
      printf "Approve any pending OpenClaw gateway scope prompt, then run './bin/openclaw cron-install'.\n"
    fi
    ;;
  cron-install)
    install_cron_jobs
    ;;
  cron-list)
    cron_exec list
    ;;
  set-keyboard)
    set_keyboard
    ;;
  reset-sessions)
    shift
    reset_sessions "$@"
    ;;
  doctor)
    shift
    gateway_node doctor "$@"
    ;;
  migrate-codex)
    gateway_node migrate codex
    ;;
  config)
    print_config
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
