#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
COMPOSE=(docker compose --project-directory "$ROOT" --file "$ROOT/docker-compose.yml")
SERVICE_URL="${JOBHUNTER_SERVICE_URL:-http://127.0.0.1:8765}"
GATEWAY_URL="${OPENCLAW_GATEWAY_URL:-http://127.0.0.1:18789}"
DRY_RUN="${OPENCLAW_DRY_RUN:-0}"

usage() {
  cat <<'EOF'
Usage: ./bin/openclaw <command>

Commands:
  start     Build and start jobhunter-service + openclaw-gateway
  stop      Stop jobhunter-service + openclaw-gateway
  restart   Recreate jobhunter-service + openclaw-gateway
  logs      Follow both logs; use "logs gateway" or "logs service"
  status    Show service and gateway status
  shell     Open a shell; use "shell gateway" or "shell service"
  onboard   Run Dockerized OpenClaw onboarding without host daemon install
  doctor    Run OpenClaw doctor inside the gateway image
  migrate-codex  Run OpenClaw Codex auth migration inside the gateway image
  config    Print suggested OpenClaw config snippet
  help      Show this help
EOF
}

run_cmd() {
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

service_health() {
  local health
  health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' jobhunter-service 2>/dev/null || true)"
  case "$health" in
    healthy|running) printf "ok\n" ;;
    starting) printf "starting\n" ;;
    unhealthy|exited|dead) printf "bad\n" ;;
    *) printf "down\n" ;;
  esac
}

gateway_health() {
  python3 - "$GATEWAY_URL" <<'PY'
import sys
import urllib.request

try:
    with urllib.request.urlopen(sys.argv[1].rstrip("/") + "/healthz", timeout=2) as response:
        print("ok" if 200 <= response.status < 300 else "bad")
except Exception:
    print("down")
PY
}

container_state() {
  docker inspect -f '{{.State.Status}}' "$1" 2>/dev/null || printf missing
}

gateway_node() {
  run_cmd "${COMPOSE[@]}" run --rm --no-deps --entrypoint node openclaw-gateway dist/index.js "$@"
}

config_patch() {
  local payload="$1"
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" run --rm --no-deps --entrypoint node openclaw-gateway dist/index.js config patch --stdin
    printf ' <<< %q\n' "$payload"
  else
    printf '%s\n' "$payload" | "${COMPOSE[@]}" run --rm --no-deps --entrypoint node openclaw-gateway dist/index.js config patch --stdin
  fi
}

patch_jobhunter_openclaw_config() {
  local payload='{"channels":{"telegram":{"capabilities":{"inlineButtons":"dm"},"actions":{"sendMessage":true}}},"mcp":{"servers":{"jobhunter":{"command":"python3","args":["-m","jobhunter.openclaw_mcp"],"cwd":"/opt/jobhunter","env":{"JOBHUNTER_SERVICE_URL":"http://jobhunter-service:8765"}}}},"skills":{"load":{"extraDirs":["/openclaw/skills"]}},"agents":{"defaults":{"agentRuntime":{"id":"codex"},"model":{"primary":"openai-codex/gpt-5.5"},"models":{"openai-codex/gpt-5.5":{}},"skills":["jobhunter"],"sandbox":{"mode":"off"}}},"plugins":{"entries":{"codex":{"enabled":true,"config":{"codexDynamicToolsProfile":"native-first","codexDynamicToolsExclude":[],"appServer":{"approvalPolicy":"on-request","sandbox":"read-only","serviceTier":"fast"}}}}},"tools":{"profile":"messaging","alsoAllow":["web_search","web_fetch"],"deny":["group:runtime","group:fs","group:automation"],"fs":{"workspaceOnly":true},"exec":{"security":"deny","ask":"always"},"elevated":{"enabled":false}}}'
  config_patch "$payload"
}

patch_codex_mcp_approval() {
  local script='from pathlib import Path
import re

path = Path("/home/node/.openclaw/agents/main/agent/codex-home/config.toml")
text = path.read_text() if path.exists() else ""

def strip_table(source, table):
    return re.sub(r"(?ms)^\[" + re.escape(table) + r"\]\n.*?(?=^\[|\Z)", "", source).strip()

trusted_workspace = "[projects.\"/home/node/.openclaw/workspace\"]"
prefix = ""
if trusted_workspace not in text:
    prefix = trusted_workspace + "\ntrust_level = \"trusted\"\n\n"

text = strip_table(text, "mcp_servers.jobhunter.env")
text = strip_table(text, "mcp_servers.jobhunter")
block = """[mcp_servers.jobhunter]
default_tools_approval_mode = "approve"
command = "python3"
args = ["-m", "jobhunter.openclaw_mcp"]
cwd = "/opt/jobhunter"

[mcp_servers.jobhunter.env]
JOBHUNTER_SERVICE_URL = "http://jobhunter-service:8765"
"""
next_text = (prefix + text.strip() + "\n\n" + block).strip() + "\n"
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(next_text)
print(path)
'
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" run --rm --no-deps --entrypoint python3 openclaw-gateway -c "$script"
    printf '\n'
  else
    "${COMPOSE[@]}" run --rm --no-deps --entrypoint python3 openclaw-gateway -c "$script"
  fi
}

register_codex_mcp_jobhunter() {
  # Empirically required for Codex CLI 0.128.0: writing [mcp_servers.jobhunter]
  # to ~/.codex/config.toml is necessary but NOT sufficient for Codex
  # app-server to register the MCP tools at startup. `codex mcp add` must run
  # separately so Codex's own runtime registry sees the server as enabled.
  local cmd=(env HOME=/home/node/.openclaw/agents/main/agent/codex-home /home/node/.openclaw/npm/node_modules/@openai/codex/bin/codex.js mcp add jobhunter --env JOBHUNTER_SERVICE_URL=http://jobhunter-service:8765 -- python3 -m jobhunter.openclaw_mcp)
  if [ "$DRY_RUN" = "1" ]; then
    printf '+'
    printf ' %q' "${COMPOSE[@]}" exec -T openclaw-gateway "${cmd[@]}"
    printf '\n'
  else
    "${COMPOSE[@]}" exec -T openclaw-gateway "${cmd[@]}" || true
  fi
}

print_config() {
  cat <<EOF
{
  // Dockerized Phase 1.5 config. Gateway runs in container, so paths are
  // container-relative and the Jobhunter service is reached over Compose DNS.
  // Run './bin/openclaw onboard' to apply this and to set Codex's per-agent
  // [mcp_servers.jobhunter].default_tools_approval_mode = "approve".
  channels: {
    telegram: {
      capabilities: {
        inlineButtons: "dm"
      },
      actions: {
        sendMessage: true
      }
    }
  },
  mcp: {
    servers: {
      jobhunter: {
        command: "python3",
        args: ["-m", "jobhunter.openclaw_mcp"],
        cwd: "/opt/jobhunter",
        env: {
          JOBHUNTER_SERVICE_URL: "http://jobhunter-service:8765"
        }
      }
    }
  },
  skills: {
    load: {
      extraDirs: ["/openclaw/skills"]
    }
  },
  agents: {
    defaults: {
      agentRuntime: {
        id: "codex"
      },
      model: {
        primary: "openai-codex/gpt-5.5"
      },
      models: {
        "openai-codex/gpt-5.5": {}
      },
      skills: ["jobhunter"],
      sandbox: {
        mode: "off"
      }
    }
  },
  plugins: {
    entries: {
      codex: {
        enabled: true,
        config: {
          codexDynamicToolsProfile: "native-first",
          codexDynamicToolsExclude: [],
          appServer: {
            approvalPolicy: "on-request",
            sandbox: "read-only",
            serviceTier: "fast"
          }
        }
      }
    }
  },
  tools: {
    profile: "messaging",
    alsoAllow: ["web_search", "web_fetch"],
    deny: ["group:runtime", "group:fs", "group:automation"],
    fs: { workspaceOnly: true },
    exec: { security: "deny", ask: "always" },
    elevated: { enabled: false }
  }
}
EOF
}

case "${1:-help}" in
  help|-h|--help)
    usage
    ;;
  start)
    run_cmd "${COMPOSE[@]}" build jobhunter-service openclaw-gateway
    run_cmd "${COMPOSE[@]}" up -d jobhunter-service openclaw-gateway
    printf "jobhunter-service: %s\n" "$(service_health)"
    printf "openclaw-gateway: %s\n" "$(gateway_health)"
    printf "\nRun './bin/openclaw onboard' once before first Telegram pairing.\n"
    ;;
  stop)
    run_cmd "${COMPOSE[@]}" stop openclaw-gateway jobhunter-service
    ;;
  restart)
    run_cmd "${COMPOSE[@]}" up -d --force-recreate --build jobhunter-service openclaw-gateway
    printf "jobhunter-service: %s\n" "$(service_health)"
    printf "openclaw-gateway: %s\n" "$(gateway_health)"
    ;;
  logs)
    case "${2:-all}" in
      gateway)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" openclaw-gateway
        ;;
      service)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" jobhunter-service
        ;;
      all)
        run_cmd "${COMPOSE[@]}" logs -f --tail="${TAIL:-100}" jobhunter-service openclaw-gateway
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    ;;
  status)
    printf "jobhunter-service:%s health:%s\n" "$(container_state jobhunter-service)" "$(service_health)"
    printf "openclaw-gateway:%s health:%s\n" "$(container_state openclaw-gateway)" "$(gateway_health)"
    ;;
  shell)
    case "${2:-service}" in
      gateway)
        run_cmd "${COMPOSE[@]}" exec openclaw-gateway sh
        ;;
      service)
        run_cmd "${COMPOSE[@]}" exec jobhunter-service sh
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    ;;
  onboard)
    gateway_node onboard --mode local --no-install-daemon
    gateway_node config set --batch-json '[{"path":"gateway.mode","value":"local"},{"path":"gateway.bind","value":"lan"},{"path":"gateway.controlUi.allowedOrigins","value":["http://localhost:18789","http://127.0.0.1:18789"]}]'
    patch_jobhunter_openclaw_config
    patch_codex_mcp_approval
    register_codex_mcp_jobhunter
    printf "\nOnboarding finished. Jobhunter MCP, skill, Telegram, Codex runtime, Codex MCP approval, and Codex CLI registry are configured.\n"
    ;;
  doctor)
    shift
    gateway_node doctor "$@"
    ;;
  migrate-codex)
    gateway_node migrate codex
    ;;
  config)
    print_config
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
