// Docker gateway example. Copy relevant sections into the OpenClaw config stored
// in the openclaw_home Docker volume after running:
//   ./bin/openclaw onboard
// Validate with:
//   ./bin/openclaw config
//
// Phase 1.5 keeps the gateway itself in Docker, so per-agent sandboxing is off:
// mounting /var/run/docker.sock into the gateway is explicitly forbidden.
// Safety is enforced by narrow mounts, no shell exec, deny-lists, and bounded
// Jobhunter MCP tools.
{
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: ["tg:${TELEGRAM_ALLOWED_CHAT_ID}"],
    },
  },
  mcp: {
    servers: {
      jobhunter: {
        command: "python3",
        args: ["-m", "jobhunter.openclaw_mcp"],
        cwd: "/opt/jobhunter",
        env: {
          JOBHUNTER_SERVICE_URL: "http://jobhunter-service:8765",
        },
      },
    },
  },
  skills: {
    load: {
      extraDirs: ["/openclaw/skills"],
    },
  },
  agents: {
    defaults: {
      model: "openai/gpt-5.5",
      skills: ["jobhunter"],
      sandbox: {
        mode: "off",
      },
      tools: {
        profile: "messaging",
        deny: ["group:runtime", "group:fs", "group:automation"],
        allow: ["group:messaging", "bundle-mcp", "web_search", "web_fetch"],
        fs: {
          workspaceOnly: true,
        },
        exec: {
          security: "deny",
          ask: "always",
        },
        elevated: {
          enabled: false,
        },
      },
    },
    list: [
      {
        id: "jobs",
        skills: ["jobhunter"],
      },
      {
        id: "leads",
        skills: ["leadhunter"],
      },
    ],
  },
}
